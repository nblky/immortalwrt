/dts-v1/;

#include "ipq8074.dtsi"
#include "ipq8074-hk-cpu.dtsi"
#include "ipq8074-ess.dtsi"
#include "ipq8074-nss.dtsi"

#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>
#include <dt-bindings/leds/common.h>

/ {
	model = "Arista AP-C260";
	compatible = "arista,c260", "qcom,ipq8074";

	aliases {
		serial0 = &blsp1_uart5;
		ethernet0 = &dp5_syn;
		ethernet1 = &dp6_syn;
		label-mac-device = &dp5_syn;

		led-boot = &led_power_green;
		led-failsafe = &led_power_red;
		led-running = &led_power_green;
		led-upgrade = &led_power_red;
	};

	chosen {
		stdout-path = "serial0:115200n8";
		bootargs-append = " ubi.mtd=rootfs ubi.block=0,rootfs root=/dev/ubiblock0_0 rootfstype=squashfs rootwait coherent_pool=2M pcie_aspm=off";
	};

	keys {
		compatible = "gpio-keys";
		pinctrl-0 = <&button_pins>;
		pinctrl-names = "default";

		reset {
			label = "reset";
			gpios = <&tlmm 52 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_RESTART>;
			debounce-interval = <60>;
		};
	};

	led-spi {
		compatible = "spi-gpio";
		pinctrl-0 = <&led_spi_pins>;
		pinctrl-names = "default";
		#address-cells = <1>;
		#size-cells = <0>;

		sck-gpios = <&tlmm 18 GPIO_ACTIVE_HIGH>;
		mosi-gpios = <&tlmm 19 GPIO_ACTIVE_HIGH>;

		led_gpio: led-gpio@0 {
			compatible = "fairchild,74hc595";
			reg = <0>;
			gpio-controller;
			#gpio-cells = <2>;
			registers-number = <2>;
			enable-gpios = <&tlmm 20 GPIO_ACTIVE_HIGH>;
			spi-max-frequency = <1000000>;
		};
	};

	leds {
		compatible = "gpio-leds";

		led_eth2_green: eth2-green {
			label = "green:eth2";
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_LAN;
			gpios = <&led_gpio 0 GPIO_ACTIVE_HIGH>;
			default-state = "off";
		};

		led_eth2_red: eth2-red {
			label = "red:eth2";
			color = <LED_COLOR_ID_RED>;
			function = LED_FUNCTION_LAN;
			gpios = <&led_gpio 1 GPIO_ACTIVE_HIGH>;
			default-state = "off";
		};

		led_eth1_green: eth1-green {
			label = "green:eth1";
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_LAN;
			gpios = <&led_gpio 2 GPIO_ACTIVE_HIGH>;
			default-state = "off";
		};

		led_eth1_red: eth1-red {
			label = "red:eth1";
			color = <LED_COLOR_ID_RED>;
			function = LED_FUNCTION_LAN;
			gpios = <&led_gpio 3 GPIO_ACTIVE_HIGH>;
			default-state = "off";
		};

		led_wlan3_green: wlan3-green {
			label = "green:wlan3";
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_WLAN;
			gpios = <&led_gpio 4 GPIO_ACTIVE_HIGH>;
			default-state = "off";
		};

		led_wlan3_red: wlan3-red {
			label = "red:wlan3";
			color = <LED_COLOR_ID_RED>;
			function = LED_FUNCTION_WLAN;
			gpios = <&led_gpio 5 GPIO_ACTIVE_HIGH>;
			default-state = "off";
		};

		led_wlan5g_green: wlan5g-green {
			label = "green:wlan5g";
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_WLAN_5GHZ;
			gpios = <&led_gpio 8 GPIO_ACTIVE_HIGH>;
			default-state = "off";
		};

		led_wlan5g_red: wlan5g-red {
			label = "red:wlan5g";
			color = <LED_COLOR_ID_RED>;
			function = LED_FUNCTION_WLAN_5GHZ;
			gpios = <&led_gpio 9 GPIO_ACTIVE_HIGH>;
			default-state = "off";
		};

		led_wlan2g_green: wlan2g-green {
			label = "green:wlan2g";
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_WLAN_2GHZ;
			gpios = <&led_gpio 10 GPIO_ACTIVE_HIGH>;
			default-state = "off";
		};

		led_wlan2g_red: wlan2g-red {
			label = "red:wlan2g";
			color = <LED_COLOR_ID_RED>;
			function = LED_FUNCTION_WLAN_2GHZ;
			gpios = <&led_gpio 11 GPIO_ACTIVE_HIGH>;
			default-state = "off";
		};

		led_power_green: power-green {
			label = "green:power";
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_POWER;
			gpios = <&led_gpio 12 GPIO_ACTIVE_HIGH>;
			default-state = "on";
		};

		led_power_red: power-red {
			label = "red:power";
			color = <LED_COLOR_ID_RED>;
			function = LED_FUNCTION_POWER;
			gpios = <&led_gpio 13 GPIO_ACTIVE_HIGH>;
			default-state = "off";
		};
	};
};

&tlmm {
	button_pins: button-pins {
		reset-pins {
			pins = "gpio52";
			function = "gpio";
			drive-strength = <8>;
			bias-pull-up;
		};
	};

	led_spi_pins: led-spi-pins {
		led-clock {
			pins = "gpio18";
			function = "gpio";
			drive-strength = <8>;
			bias-pull-down;
		};

		led-data {
			pins = "gpio19";
			function = "gpio";
			drive-strength = <8>;
			bias-pull-down;
		};

		led-enable {
			pins = "gpio20";
			function = "gpio";
			drive-strength = <8>;
			bias-pull-up;
		};
	};

	mdio_pins: mdio-pins {
		mdc {
			pins = "gpio68";
			function = "mdc";
			drive-strength = <8>;
			bias-pull-up;
		};

		mdio {
			pins = "gpio69";
			function = "mdio";
			drive-strength = <8>;
			bias-pull-up;
		};

		phy-reset-0 {
			pins = "gpio25";
			function = "gpio";
			bias-pull-up;
		};

		phy-reset-1 {
			pins = "gpio44";
			function = "gpio";
			bias-pull-up;
		};
	};
};

&blsp1_uart5 {
	status = "okay";
};

&prng {
	status = "okay";
};

&cryptobam {
	status = "okay";
};

&crypto {
	status = "okay";
};

&blsp1_spi1 {
	cs-select = <0>;
	status = "okay";

	flash@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <50000000>;

		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;

			partition@0 {
				label = "0:SBL1";
				reg = <0x0 0x50000>;
				read-only;
			};

			partition@50000 {
				label = "0:MIBIB";
				reg = <0x50000 0x10000>;
				read-only;
			};

			partition@60000 {
				label = "0:BOOTCONFIG";
				reg = <0x60000 0x20000>;
			};

			partition@80000 {
				label = "0:BOOTCONFIG1";
				reg = <0x80000 0x20000>;
			};

			partition@a0000 {
				label = "0:QSEE";
				reg = <0xa0000 0x180000>;
				read-only;
			};

			partition@220000 {
				label = "0:QSEE_1";
				reg = <0x220000 0x180000>;
				read-only;
			};

			partition@3a0000 {
				label = "0:DEVCFG";
				reg = <0x3a0000 0x10000>;
				read-only;
			};

			partition@3b0000 {
				label = "0:DEVCFG_1";
				reg = <0x3b0000 0x10000>;
				read-only;
			};

			partition@3c0000 {
				label = "0:APDP";
				reg = <0x3c0000 0x10000>;
				read-only;
			};

			partition@3d0000 {
				label = "0:APDP_1";
				reg = <0x3d0000 0x10000>;
				read-only;
			};

			partition@3e0000 {
				label = "0:RPM";
				reg = <0x3e0000 0x40000>;
				read-only;
			};

			partition@420000 {
				label = "0:RPM_1";
				reg = <0x420000 0x40000>;
				read-only;
			};

			partition@460000 {
				label = "0:CDT";
				reg = <0x460000 0x10000>;
				read-only;
			};

			partition@470000 {
				label = "0:CDT_1";
				reg = <0x470000 0x10000>;
				read-only;
			};

			partition@480000 {
				label = "0:APPSBLENV";
				reg = <0x480000 0x10000>;
			};

			partition@490000 {
				label = "0:APPSBL";
				reg = <0x490000 0x100000>;
				read-only;
			};

			partition@590000 {
				label = "0:APPSBL_1";
				reg = <0x590000 0x100000>;
				read-only;
			};

			partition@690000 {
				label = "0:ART";
				reg = <0x690000 0x40000>;
				read-only;
			};

			partition@6d0000 {
				label = "0:ETHPHYFW";
				reg = <0x6d0000 0x80000>;
				read-only;
			};

			partition@750000 {
				label = "0:HLOS";
				reg = <0x750000 0x800000>;
			};

			partition@f50000 {
				label = "0:HLOS_1";
				reg = <0xf50000 0x800000>;
			};

			partition@1750000 {
				label = "CONFIG";
				reg = <0x1750000 0x400000>;
			};

			partition@1b50000 {
				label = "LOGGING";
				reg = <0x1b50000 0x100000>;
			};

			partition@1c50000 {
				label = "RESERVED";
				reg = <0x1c50000 0x3b0000>;
			};
		};
	};
};

&qpic_bam {
	status = "okay";
};

&qpic_nand {
	status = "okay";

	nand@0 {
		reg = <0>;
		nand-ecc-strength = <4>;
		nand-ecc-step-size = <512>;
		nand-bus-width = <8>;

		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;

			partition@0 {
				label = "rootfs";
				reg = <0x0 0x10000000>;
			};

			partition@10000000 {
				label = "rootfs_1";
				reg = <0x10000000 0x10000000>;
			};
		};
	};
};

&mdio {
	status = "okay";
	pinctrl-0 = <&mdio_pins>;
	pinctrl-names = "default";

	phy0: ethernet-phy@0 {
		compatible = "ethernet-phy-ieee802.3-c45";
		reg = <0>;
		#thermal-sensor-cells = <0>;
	};

	phy8: ethernet-phy@8 {
		compatible = "ethernet-phy-ieee802.3-c45";
		reg = <8>;
		#thermal-sensor-cells = <0>;
	};
};

&switch {
	status = "okay";

	switch_lan_bmp = <0x20>;
	switch_wan_bmp = <0x40>;
	switch_mac_mode = <0xff>;
	switch_mac_mode1 = <0xd>;
	switch_mac_mode2 = <0xd>;

	qcom,port_phyinfo {
		port@5 {
			port_id = <5>;
			phy_address = <8>;
			compatible = "ethernet-phy-ieee802.3-c45";
			ethernet-phy-ieee802.3-c45;
		};

		port@6 {
			port_id = <6>;
			phy_address = <0>;
			compatible = "ethernet-phy-ieee802.3-c45";
			ethernet-phy-ieee802.3-c45;
		};
	};
};

&edma {
	status = "okay";
};

&dp5_syn {
	status = "okay";
	phy-mode = "usxgmii";
	phy-handle = <&phy8>;
	label = "eth1";
};

&dp6_syn {
	status = "okay";
	phy-mode = "usxgmii";
	phy-handle = <&phy0>;
	label = "eth2";
};


/*
 * AP-C260 has a PCIe QCA988X multipurpose third radio on PCIe0.
 * Keep it disabled by default; enabling it shifts radio numbering to:
 *   phy0 = QCA988X third radio, phy1 = 5G, phy2 = 2.4G.
 */
&pcie_qmp0 {
	status = "disabled";
};

&pcie0 {
	status = "disabled";

	perst-gpio = <&tlmm 58 GPIO_ACTIVE_LOW>;
};

&wifi {
	status = "okay";
	qcom,ath11k-fw-memory-mode = <1>;
	qcom,ath11k-calibration-variant = "Arista-C260";
};
