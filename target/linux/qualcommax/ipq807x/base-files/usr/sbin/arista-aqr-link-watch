#!/bin/sh

. /lib/functions.sh

case "$(board_name)" in
arista,c260|arista,c360)
	;;
*)
	exit 0
	;;
esac

INTERVAL=${INTERVAL:-3}
DOWN_GRACE=${DOWN_GRACE:-18}
RESTART_COOLDOWN=${RESTART_COOLDOWN:-18}
RESET_COOLDOWN=${RESET_COOLDOWN:-60}
PORTS=${PORTS:-"eth1 eth2"}
STATE_DIR=/tmp/run/arista-aqr-link-watch

# AP-C260/AP-C360 use two C45 AQR PHYs: eth1 -> phy@8, eth2 -> phy@0.
# The GPIO numbers below are TLMM line numbers; gpio_num() converts them to
# sysfs GPIO numbers at runtime because the gpiochip base can vary.
phy_reset_line()
{
	case "$1" in
	eth1) echo 44 ;;
	eth2) echo 25 ;;
	*) return 1 ;;
	esac
}

mkdir -p "$STATE_DIR"

now_s()
{
	awk "{ print int(\$1) }" /proc/uptime
}

admin_is_up()
{
	local flags

	flags=$(cat "/sys/class/net/$1/flags" 2>/dev/null) || return 1
	[ $((flags & 1)) -ne 0 ]
}

link_change_count()
{
	cat "/sys/class/net/$1/carrier_changes" 2>/dev/null || echo 0
}

gpio_num()
{
	local line="$1" chip base ngpio label

	for chip in /sys/class/gpio/gpiochip*; do
		[ -e "$chip/base" ] || continue
		base=$(cat "$chip/base" 2>/dev/null) || continue
		ngpio=$(cat "$chip/ngpio" 2>/dev/null) || continue
		label=$(cat "$chip/label" 2>/dev/null)

		case "$label" in
		*pinctrl*|*tlmm*|*qcom*) ;;
		*) [ "$ngpio" -ge 70 ] 2>/dev/null || continue ;;
		esac

		if [ "$line" -lt "$ngpio" ] 2>/dev/null; then
			echo $((base + line))
			return 0
		fi
	done

	return 1
}

gpio_write()
{
	local gpio="$1" value="$2" dir="/sys/class/gpio/gpio$gpio"

	[ -d "$dir" ] || echo "$gpio" > /sys/class/gpio/export 2>/dev/null || return 1
	echo out > "$dir/direction" 2>/dev/null || return 1
	echo "$value" > "$dir/value" 2>/dev/null || return 1
}

remember_down_event()
{
	local dev="$1" changes now
	changes=$(link_change_count "$dev")
	now=$(now_s)

	if [ "$(cat "$STATE_DIR/$dev.changes" 2>/dev/null)" != "$changes" ]; then
		echo "$changes" > "$STATE_DIR/$dev.changes"
		echo "$now" > "$STATE_DIR/$dev.down_since"
		echo 0 > "$STATE_DIR/$dev.stage"
	fi
}

restart_aneg()
{
	local dev="$1"

	logger -t arista-aqr-link-watch "$dev carrier is still down, restarting PHY autoneg"
	ethtool -s "$dev" autoneg on >/dev/null 2>&1 || true
	ethtool -r "$dev" >/dev/null 2>&1 || true
}

reset_netdev()
{
	local dev="$1"

	logger -t arista-aqr-link-watch "$dev carrier is still down after autoneg retries, cycling netdev"
	ip link set dev "$dev" down >/dev/null 2>&1 || return
	sleep 2
	ip link set dev "$dev" up >/dev/null 2>&1 || true
}

reset_phy_gpio()
{
	local dev="$1" line gpio

	line=$(phy_reset_line "$dev") || return 1
	gpio=$(gpio_num "$line") || return 1

	logger -t arista-aqr-link-watch "$dev carrier is still down after netdev cycle, pulsing PHY reset gpio$line"
	ip link set dev "$dev" down >/dev/null 2>&1 || true
	gpio_write "$gpio" 1 || return 1
	sleep 0.1
	gpio_write "$gpio" 0 || return 1
	sleep 0.3
	gpio_write "$gpio" 1 || return 1
	sleep 3
	ip link set dev "$dev" up >/dev/null 2>&1 || true
	restart_aneg "$dev"
}

while :; do
	for dev in $PORTS; do
		[ -e "/sys/class/net/$dev" ] || continue

		if ! admin_is_up "$dev"; then
			echo 0 > "$STATE_DIR/$dev.stage"
			continue
		fi

		carrier=$(cat "/sys/class/net/$dev/carrier" 2>/dev/null || echo 0)
		if [ "$carrier" = "1" ]; then
			echo "$(link_change_count "$dev")" > "$STATE_DIR/$dev.changes"
			echo 0 > "$STATE_DIR/$dev.stage"
			continue
		fi

		remember_down_event "$dev"
		now=$(now_s)
		down_since=$(cat "$STATE_DIR/$dev.down_since" 2>/dev/null || echo "$now")
		[ $((now - down_since)) -ge "$DOWN_GRACE" ] || continue

		last=$(cat "$STATE_DIR/$dev.last" 2>/dev/null || echo 0)
		[ $((now - last)) -ge "$RESTART_COOLDOWN" ] || continue

		stage=$(cat "$STATE_DIR/$dev.stage" 2>/dev/null || echo 0)
		stage=$((stage + 1))
		echo "$stage" > "$STATE_DIR/$dev.stage"
		echo "$now" > "$STATE_DIR/$dev.last"

		case "$stage" in
			1|2|4|5)
				restart_aneg "$dev"
				;;
			3|6)
				last_reset=$(cat "$STATE_DIR/$dev.last_reset" 2>/dev/null || echo 0)
				if [ $((now - last_reset)) -ge "$RESET_COOLDOWN" ]; then
					reset_netdev "$dev"
					echo "$now" > "$STATE_DIR/$dev.last_reset"
				else
					restart_aneg "$dev"
				fi
				;;
			*)
				last_gpio_reset=$(cat "$STATE_DIR/$dev.last_gpio_reset" 2>/dev/null || echo 0)
				if [ $((now - last_gpio_reset)) -ge "$RESET_COOLDOWN" ]; then
					reset_phy_gpio "$dev" || reset_netdev "$dev"
					echo "$now" > "$STATE_DIR/$dev.last_gpio_reset"
				else
					restart_aneg "$dev"
				fi
				;;
		esac
	done

	sleep "$INTERVAL"
done
